{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Glob",
      "Grep",
      "LS",
      "Edit(<project>/**)",
      "Write(<project>/**)",
      "MultiEdit(<project>/**)",
      "Delete(<project>/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)",
      "NotebookRead",
      "NotebookEdit(<project>/**/*.ipynb)",
      "mcp__*",
      "Skill(*)",
      "Task(*)",
      "Agent(*)",
      "TodoRead",
      "TodoWrite",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "claude-context",
    "context7",
    "sequentialthinking"
  ],
  "enabledPlugins": {"everything-claude-code@everything-claude-code": true}
}
